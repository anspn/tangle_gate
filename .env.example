# =============================================================================
# .env — Docker Compose environment variables
# ============================================================================
# This is the SINGLE source of truth for all container configuration.
# Docker Compose passes these vars directly to the container via env_file.
# Uncomment optional vars to override the defaults defined in runtime.exs.
# =============================================================================

# Required: JWT signing secret (generate with: openssl rand -base64 64)
SECRET_KEY_BASE=changeme

# Required: Admin user password
ADMIN_PASSWORD=changeme

# Required: MongoDB password (used by both mongo container and app connection string)
MONGO_PASSWORD=changeme

# Required: Vault root token (used by Vault dev server and app client)
VAULT_ROOT_TOKEN=changeme

# Optional: IOTA node URL (default: IOTA testnet)
# IOTA_NODE_URL=https://api.testnet.iota.cafe
# To use a local node from Docker, set:
# IOTA_NODE_URL=http://host.docker.internal:9000

# Optional: Faucet URL
# IOTA_FAUCET_URL=https://faucet.testnet.iota.cafe/gas

# Optional: Move package ObjectIDs (empty = auto-discovery)
# IOTA_IDENTITY_PKG_ID=
# IOTA_NOTARIZE_PKG_ID=

# Optional: IOTA Ed25519 secret key — used for on-chain session notarization
# and as the default key for DID publishing when not provided per-call.
# If not set here, the wallet init container auto-generates one and writes it
# to a shared volume. The app reads it via its entrypoint script.
# Set this variable explicitly to override the wallet-generated key.
# When Vault is enabled (default in prod), Vault takes final precedence.
# IOTA_SECRET_KEY=iotaprivkey1...

# Optional: MongoDB connection settings
# MONGO_USERNAME=iota              # default: iota
# MONGO_POOL_SIZE=10               # connection pool size (default: 10)

# Optional: Vault settings
# VAULT_ENABLED=true               # set to "false" to disable Vault (default: true in prod)
# VAULT_MOUNT=secret              # KV v2 mount path
# VAULT_SECRET_PATH=tangle_gate  # secret key path in Vault

# Optional: Web server port
# PORT=4000

# Optional: Admin user details
# ADMIN_EMAIL=admin@iota.local
# ADMIN_USER_ID=usr_admin

# Optional: Verifier role account (notarization verification, set password to enable)
# VERIFIER_PASSWORD=changeme
# VERIFIER_EMAIL=verifier@iota.local
# VERIFIER_USER_ID=usr_verifier

# Optional: JWT token TTL in seconds
# TOKEN_TTL_SECONDS=3600

# Optional: ttyd terminal URL (user-facing, browser connects to this)
# TTYD_URL=/terminal
# TRAEFIK_PORT=8980               # host port for Traefik reverse proxy

# Optional: Backend container session user password (default: sessionpass)
# SESSION_USER_PASSWORD=sessionpass

# Optional: Session recording directory (shared Docker volume with ttyd)
# SESSIONS_DIR=/data/sessions

# Required: TangleGate Agent API key (shared secret between app and agent)
AGENT_API_KEY=changeme

# Optional: TangleGate Agent microservice
# AGENT_URL=http://localhost:8800
# AGENT_TIMEOUT=30000

# Optional: Email notifications (SMTP)
# EMAIL_ENABLED=false              # set to "true" to enable email notifications
# EMAIL_FROM=tangle_gate@tanglegate.dev
# SMTP_RELAY=localhost
# SMTP_PORT=25
# SMTP_USERNAME=
# SMTP_PASSWORD=

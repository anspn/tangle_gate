# TangleGate Agent environment variables
# Copy to /etc/tangle_gate_agent/env and fill in values

# Required: Shared API key between tangle_gate and the agent
AGENT_API_KEY=change-me-to-a-secure-random-string

# Agent HTTP server port
PORT=8800

# IOTA node URL for on-chain DID resolution
IOTA_NODE_URL=https://api.testnet.iota.cafe

# Identity package ObjectID (empty string for auto-discovery)
IOTA_IDENTITY_PKG_ID=

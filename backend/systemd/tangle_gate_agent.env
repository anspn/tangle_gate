# Environment file for tangle_gate_agent systemd service
# Values are injected by the configure.sh script at container startup
# from Docker environment variables.

AGENT_API_KEY=dev-agent-key
IOTA_NODE_URL=https://api.testnet.iota.cafe
IOTA_IDENTITY_PKG_ID=
PORT=8800
AGENT_WS_URL=ws://localhost:8800/ws/events
HOME=/opt/tangle_gate_agent
